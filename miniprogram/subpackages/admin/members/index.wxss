page {
  background: #0b1120;
}

.admin-members {
  min-height: 100vh;
  min-height: calc(100vh - constant(safe-area-inset-top) - constant(safe-area-inset-bottom));
  min-height: calc(100vh - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #0b1120;
  color: #e2e8f0;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.sort-bar {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 20;
}

.sort-label {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
}

.sort-picker {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #e2e8f0;
  border: 1px solid rgba(148, 163, 184, 0.35);
  background: rgba(15, 23, 42, 0.7);
}

.sort-arrow {
  color: #94a3b8;
  font-size: 22rpx;
}

.sort-menu-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 21;
}

.sort-menu {
  position: absolute;
  top: calc(100% + 10rpx);
  left: 0;
  width: 100%;
  background: rgba(15, 23, 42, 0.98);
  border: 1px solid rgba(148, 163, 184, 0.35);
  border-radius: 16rpx;
  overflow: hidden;
  z-index: 22;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.35);
}

.sort-menu-item {
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #cbd5f5;
  border-bottom: 1px solid rgba(148, 163, 184, 0.2);
}

.sort-menu-item:last-child {
  border-bottom: none;
}

.sort-menu-item--active {
  color: #f97316;
  background: rgba(30, 41, 59, 0.9);
}

.search-input {
  flex: 1 1 auto;
  background: rgba(15, 23, 42, 0.8);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  color: #f8fafc;
  border: 1px solid rgba(148, 163, 184, 0.3);
}

.search-button {
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  flex: 0 0 160rpx;
  padding: 16rpx 0;
  text-align: center;
  font-size: 28rpx;
}

.loading,
.empty,
.end {
  text-align: center;
  padding: 48rpx 0;
  color: #94a3b8;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.member-item {
  display: flex;
  align-items: center;
  background: rgba(15, 23, 42, 0.85);
  border: 1px solid rgba(148, 163, 184, 0.2);
  border-radius: 20rpx;
  padding: 24rpx;
  backdrop-filter: blur(12px);
}

.member-item:active {
  opacity: 0.85;
}

.member-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #1e293b;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.member-meta {
  font-size: 26rpx;
  color: #94a3b8;
  margin-bottom: 6rpx;
}

.member-assets {
  font-size: 26rpx;
  color: #cbd5f5;
  margin-bottom: 6rpx;
}

.member-status {
  font-size: 26rpx;
  color: #cbd5f5;
}

.member-arrow {
  font-size: 40rpx;
  color: #64748b;
}

.loading-inline {
  text-align: center;
  padding: 24rpx 0;
  color: #94a3b8;
}

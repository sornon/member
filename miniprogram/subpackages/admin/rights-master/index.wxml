<custom-nav title="权益管理" theme="dark"></custom-nav><view class="page"><view class="card"><view class="title">新增/编辑权益</view><input placeholder="权益ID" value="{{form.rightId}}" data-field="rightId" bindinput="onInput"/><input placeholder="权益名称" value="{{form.name}}" data-field="name" bindinput="onInput"/><textarea placeholder="权益描述" value="{{form.description}}" data-field="description" bindinput="onInput"></textarea><picker mode="selector" range="{{['active','inactive']}}" value="{{form.status==='inactive'?1:0}}" bindchange="onStatusChange"><view>{{form.status}}</view></picker><picker mode="selector" range="{{['ticket','coupon']}}" value="{{form.type==='coupon'?1:0}}" bindchange="onTypeChange"><view>{{form.type}}</view></picker><button bindtap="save">保存</button></view><view class="card"><view class="title">权益列表</view><view wx:for="{{rights}}" wx:key="id" class="row"><view>{{item.rightId}}｜{{item.name}}（{{item.status}}）</view><button size="mini" data-item="{{item}}" bindtap="startEdit">编辑</button><button size="mini" data-id="{{item.id}}" bindtap="remove">删除</button></view></view></view>

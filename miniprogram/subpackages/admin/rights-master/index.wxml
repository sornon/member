<custom-nav title="权益管理" theme="dark"></custom-nav>

<view class="admin-rights">
  <view class="toolbar">
    <button class="ghost-btn" bindtap="handleBack">返回</button>
    <button class="ghost-btn" bindtap="startCreate">新建</button>
  </view>

  <view class="panel">
    <view class="panel-title">{{editingId ? '编辑权益' : '新增权益'}}</view>
    <input class="field" placeholder="权益ID（如 chamber-music-ticket）" value="{{form.rightId}}" data-field="rightId" bindinput="onInput" />
    <input class="field" placeholder="权益名称" value="{{form.name}}" data-field="name" bindinput="onInput" />
    <textarea class="field field--textarea" placeholder="权益描述" value="{{form.description}}" data-field="description" bindinput="onInput"></textarea>

    <view class="picker-row">
      <view class="picker-item">
        <text class="picker-label">状态</text>
        <picker mode="selector" range="{{statusOptions}}" value="{{form.status==='inactive'?1:0}}" bindchange="onStatusChange">
          <view class="picker-value">{{form.status}}</view>
        </picker>
      </view>
      <view class="picker-item">
        <text class="picker-label">类型</text>
        <picker mode="selector" range="{{typeOptions}}" value="{{form.type==='coupon'?1:0}}" bindchange="onTypeChange">
          <view class="picker-value">{{form.type}}</view>
        </picker>
      </view>
    </view>

    <button class="save-btn" bindtap="save">保存</button>
  </view>

  <view class="panel">
    <view class="panel-title">权益列表</view>
    <view wx:if="{{loading}}" class="state">加载中...</view>
    <view wx:elif="{{!rights.length}}" class="state">暂无权益</view>
    <view wx:else class="list">
      <view wx:for="{{rights}}" wx:key="id" class="item">
        <view class="item-main">
          <view class="item-name">{{item.name}}</view>
          <view class="item-meta">{{item.rightId}} · {{item.type}} · {{item.status}}</view>
          <view wx:if="{{item.description}}" class="item-desc">{{item.description}}</view>
        </view>
        <view class="item-actions">
          <button size="mini" class="mini-btn" data-item="{{item}}" bindtap="startEdit">编辑</button>
          <button size="mini" class="mini-btn mini-btn--danger" data-id="{{item.id}}" bindtap="remove">删除</button>
        </view>
      </view>
    </view>
  </view>
</view>
